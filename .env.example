# Discord config ############################################

# 通知を送る先の Webhook URL。
WEBHOOK_URL=https://example.com/webhook

# メンションしたいユーザーIDをカンマ区切りで指定する。
# 例: 123456789012345678,234567890123456789
DISCORD_MENTION_USER_IDS=

# Discordに通知される際に表示されるホスト名
HOSTNAME=

# Temperature config ########################################

# アラートを送る温度のしきい値(℃)。
TEMP_THRESHOLD_C=75

# 温度を確認するインターバル(ms) (1秒=1000ミリ秒)
POLL_INTERVAL_MS=60000

# 一度アラートを送ったあと、再通知まで待つ時間(ミリ秒)。
ALERT_COOLDOWN_MS=300000

# Development config ########################################

# Webhook を行わず、ログだけ出す。
DRY_RUN=false

# テスト用の温度(℃)。これを設定すると、実際の温度センサーからの値を無視してこの値を使う。
TEST_TEMPERATURE_C=

#############################################################